{
  "title": "DJI MIC MINI -> Fn + tmux confirm-to-send",
  "rules": [
    {
      "description": "Fn dictation toggle + confirm/preconfirm to send Enter",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "fn", "modifiers": { "optional": ["any"] } },
          "to": [
            { "shell_command": "~/.config/karabiner/scripts/dictation-enter.sh confirm 2>/dev/null" },
            { "set_variable": { "name": "dji_ready_to_send", "value": 0 } }
          ],
          "conditions": [
            { "type": "variable_if", "name": "dji_ready_to_send", "value": 1 }
          ]
        },
        {
          "type": "basic",
          "from": { "key_code": "fn", "modifiers": { "optional": ["any"] } },
          "to": [
            { "key_code": "fn" },
            { "shell_command": "/usr/bin/nohup ~/.config/karabiner/scripts/dictation-enter.sh watch 2>/dev/null &" },
            { "set_variable": { "name": "dji_dictation_active", "value": 0 } },
            { "set_variable": { "name": "dji_watching", "value": 1 } }
          ],
          "conditions": [
            { "type": "variable_if", "name": "dji_dictation_active", "value": 1 }
          ]
        },
        {
          "type": "basic",
          "from": { "key_code": "fn", "modifiers": { "optional": ["any"] } },
          "to": [
            { "shell_command": "~/.config/karabiner/scripts/dictation-enter.sh preconfirm 2>/dev/null" }
          ],
          "conditions": [
            { "type": "variable_if", "name": "dji_watching", "value": 1 }
          ]
        },
        {
          "type": "basic",
          "from": { "key_code": "fn", "modifiers": { "optional": ["any"] } },
          "to": [
            { "shell_command": "~/.config/karabiner/scripts/dictation-enter.sh save 2>/dev/null" },
            { "key_code": "fn" },
            { "set_variable": { "name": "dji_dictation_active", "value": 1 } }
          ],
          "conditions": [
            { "type": "variable_unless", "name": "dji_dictation_active", "value": 1 },
            { "type": "variable_unless", "name": "dji_ready_to_send", "value": 1 },
            { "type": "variable_unless", "name": "dji_watching", "value": 1 }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "volume_increment", "modifiers": { "optional": ["any"] } },
          "to": [
            { "shell_command": "~/.config/karabiner/scripts/dictation-enter.sh confirm 2>/dev/null" },
            { "set_variable": { "name": "dji_ready_to_send", "value": 0 } }
          ],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 11427, "product_id": 16401 }] },
            { "type": "variable_if", "name": "dji_ready_to_send", "value": 1 }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "volume_increment", "modifiers": { "optional": ["any"] } },
          "to": [
            { "key_code": "fn" },
            { "shell_command": "/usr/bin/nohup ~/.config/karabiner/scripts/dictation-enter.sh watch 2>/dev/null &" },
            { "set_variable": { "name": "dji_dictation_active", "value": 0 } },
            { "set_variable": { "name": "dji_watching", "value": 1 } }
          ],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 11427, "product_id": 16401 }] },
            { "type": "variable_if", "name": "dji_dictation_active", "value": 1 }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "volume_increment", "modifiers": { "optional": ["any"] } },
          "to": [
            { "shell_command": "~/.config/karabiner/scripts/dictation-enter.sh preconfirm 2>/dev/null" }
          ],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 11427, "product_id": 16401 }] },
            { "type": "variable_if", "name": "dji_watching", "value": 1 }
          ]
        },
        {
          "type": "basic",
          "from": { "consumer_key_code": "volume_increment", "modifiers": { "optional": ["any"] } },
          "to": [
            { "shell_command": "~/.config/karabiner/scripts/dictation-enter.sh save 2>/dev/null" },
            { "key_code": "fn" },
            { "set_variable": { "name": "dji_dictation_active", "value": 1 } }
          ],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 11427, "product_id": 16401 }] },
            { "type": "variable_unless", "name": "dji_dictation_active", "value": 1 },
            { "type": "variable_unless", "name": "dji_ready_to_send", "value": 1 },
            { "type": "variable_unless", "name": "dji_watching", "value": 1 }
          ]
        }
      ]
    }
  ]
}
